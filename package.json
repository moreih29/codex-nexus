{
  "name": "codex-nexus",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Nexus orchestration plugin for OpenAI Codex CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moreih29/codex-nexus.git"
  },
  "homepage": "https://github.com/moreih29/codex-nexus#readme",
  "bugs": {
    "url": "https://github.com/moreih29/codex-nexus/issues"
  },
  "keywords": [
    "codex",
    "plugin",
    "nexus",
    "agents",
    "orchestration"
  ],
  "packageManager": "bun@1.3.9",
  "bin": {
    "codex-nexus": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "prompts",
    "templates",
    ".codex-plugin",
    ".mcp.json",
    "hooks.json",
    "VERSION"
  ],
  "scripts": {
    "generate": "bun scripts/generate-from-nexus-core.mjs",
    "build": "bun scripts/build.mjs",
    "check": "bun run generate && bunx tsc --noEmit",
    "test": "bun run build && bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@moreih29/nexus-core": "^0.10.0",
    "@types/bun": "^1.2.13",
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "yaml": "^2.7.0"
  }
}
