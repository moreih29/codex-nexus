{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y -p codex-nexus@0.3.13 codex-nexus-hook session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y -p codex-nexus@0.3.13 codex-nexus-hook user-prompt-submit",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y -p codex-nexus@0.3.13 codex-nexus-hook pre-tool-use",
            "timeout": 30
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y -p codex-nexus@0.3.13 codex-nexus-hook permission-request",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y -p codex-nexus@0.3.13 codex-nexus-hook stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
